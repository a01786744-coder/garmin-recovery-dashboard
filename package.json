{
  "name": "garmin-dashboard",
  "version": "4.1.2",
  "description": "Local Whoop-style recovery dashboard sourced from Garmin Connect.",
  "author": "rodri",
  "main": "electron/main.js",
  "scripts": {
    "build:frontend": "npm --prefix frontend run build",
    "build:backend": "node scripts/freeze.js",
    "start": "npm run build:frontend && electron .",
    "dist": "npm run build:frontend && npm run build:backend && electron-builder --publish never",
    "dist:win": "npm run build:frontend && npm run build:backend && electron-builder --win --publish never",
    "dist:mac": "npm run build:frontend && npm run build:backend && electron-builder --mac --publish never",
    "test:backend": "python -m pytest backend -v"
  },
  "devDependencies": {
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.rodri.garminrecoverydashboard",
    "productName": "Garmin Recovery Dashboard",
    "directories": { "output": "release" },
    "files": [
      "electron/**",
      "package.json"
    ],
    "extraResources": [
      { "from": "pybuild/dist/garmin-backend", "to": "backend" },
      { "from": "frontend/dist", "to": "frontend" }
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.png",
      "artifactName": "GarminRecoveryDashboard-Setup-${version}.${ext}"
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.healthcare-fitness",
      "identity": null,
      "icon": "build/icon.png",
      "artifactName": "GarminRecoveryDashboard-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Garmin Recovery Dashboard"
    }
  }
}
